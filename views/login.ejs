<!DOCTYPE html>
<html>

<head>
<title>Login</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="max-w-md mx-auto mt-24 bg-white p-10 rounded-xl shadow">

<h2 class="text-3xl font-bold mb-8 text-center">
Login
</h2>

<form action="/login" method="POST" class="space-y-5">

<input name="login"
placeholder="Mobile Number OR Email"
class="border p-3 w-full rounded">

<input type="password"
name="password"
placeholder="Password"
class="border p-3 w-full rounded">

<button class="bg-green-600 text-white w-full p-3 rounded-lg">
Login
</button>

</form>

</div>

</body>
</html>