<!DOCTYPE html>
<html>

<head>
<title>Register</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="max-w-md mx-auto mt-24 bg-white p-10 rounded-xl shadow">

<h2 class="text-3xl font-bold mb-8 text-center">
Register
</h2>

<form action="/register" method="POST" class="space-y-5">

<input name="name" placeholder="Full Name"
class="border p-3 w-full rounded">

<input name="phone" placeholder="Mobile Number"
class="border p-3 w-full rounded">

<input name="email" placeholder="Email Address"
class="border p-3 w-full rounded">

<input type="password" name="password"
placeholder="Password"
class="border p-3 w-full rounded">

<select name="role" class="border p-3 w-full rounded">
<option value="user">User</option>
<option value="collector">Collector</option>
</select>

<button class="bg-green-600 text-white w-full p-3 rounded-lg">
Register
</button>

</form>

</div>

</body>
</html>