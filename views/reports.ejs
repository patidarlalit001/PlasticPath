<!DOCTYPE html>
<html>

<head>
<title>Reports</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include('partials/navbar') %>

<div class="max-w-6xl mx-auto mt-14 bg-white p-8 rounded-xl shadow">

<h2 class="text-3xl font-bold mb-8">
Plastic Reports
</h2>

<table class="w-full text-left">

<thead class="bg-green-600 text-white">

<tr>
<th class="p-4">Village</th>
<th class="p-4">Plastic (kg)</th>
<th class="p-4">Reporter</th>
<th class="p-4">Mobile</th>
<th class="p-4">Email</th>
</tr>

</thead>

<tbody>

<% reports.forEach(r=>{ %>

<tr class="border-b hover:bg-gray-50">

<td class="p-4"><%= r.village %></td>
<td class="p-4"><%= r.quantity %></td>
<td class="p-4"><%= r.reporter %></td>
<td class="p-4"><%= r.phone %></td>
<td class="p-4"><%= r.email %></td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>